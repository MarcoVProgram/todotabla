<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="720.0" maxWidth="720.0" minHeight="420.0" minWidth="420.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.decroly.todotabla.ProyectoController">
   <children>
      <Label styleClass="logo" text="Crear proyecto">
         <VBox.margin>
            <Insets bottom="80.0" />
         </VBox.margin>
      </Label>
      <HBox alignment="CENTER">
         <children>
            <Label styleClass="notice-text" text="Titulo:">
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
            <TextField fx:id="tituloProyecto">
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </TextField>
         </children>
         <VBox.margin>
            <Insets bottom="80.0" />
         </VBox.margin>
      </HBox>
      <HBox alignment="CENTER">
         <children>
            <Label styleClass="notice-text" text="Fecha de creacion:">
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </Label>
            <DatePicker fx:id="fechaProyecto" disable="true" editable="true">
               <HBox.margin>
                  <Insets left="20.0" />
               </HBox.margin>
            </DatePicker>
         </children>
         <VBox.margin>
            <Insets bottom="80.0" />
         </VBox.margin>
      </HBox>
      <HBox alignment="CENTER_RIGHT" spacing="150.0">
         <children>
            <Button fx:id="anadirUsuariosBtn" mnemonicParsing="false" onMouseClicked="#abrirVentanaUsuarios" styleClass="btnAdd" text="addUsuarios" />
            <Button fx:id="crearProyecto" defaultButton="true" mnemonicParsing="false" onAction="#guardar" text="Guardar">
               <HBox.margin>
                  <Insets right="30.0" />
               </HBox.margin>
            </Button>
         </children>
         <VBox.margin>
            <Insets bottom="5.0" />
         </VBox.margin>
      </HBox>
   </children>
   <padding>
      <Insets left="20.0" right="20.0" />
   </padding>
</VBox>
