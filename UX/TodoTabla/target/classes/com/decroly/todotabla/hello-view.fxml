<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="1000.0" prefWidth="1424.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">

    <!-- ================= HEADER ================= -->
    <top>
        <VBox>

            <!-- TOPBAR -->
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
                <padding><Insets left="16" right="16" /></padding>

                <Label styleClass="icon" text="☰" />
                <Label styleClass="logo" text="GitHub" />

                <Label styleClass="breadcrumb" text="MarcoVProgram / Projects / Todotabla" textFill="#5a92d7" />

                <Region HBox.hgrow="ALWAYS" />
                <Circle radius="14" styleClass="avatar" />
            </HBox>

            <!-- TITLE BAR -->
            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="title-bar">
                <padding><Insets bottom="12" left="16" top="12" /></padding>

                <Label styleClass="icon" text="🔒" />
                <Label styleClass="title" text="Todotabla">
               <HBox.margin>
                  <Insets right="1000.0" />
               </HBox.margin></Label>

                <Button styleClass="btn" text="Create task" />
                <Button styleClass="btn" text="Task filter" />
                <Button styleClass="btn" text="View" />
            </HBox>

            <!-- FILTER BAR -->
            <HBox alignment="CENTER" spacing="343.0" styleClass="filter-bar">
                <padding><Insets bottom="12" left="16" right="16" /></padding>

                <TextField prefHeight="33.0" prefWidth="1000.0" promptText="Filter by keyword or by field" styleClass="search-large" HBox.hgrow="ALWAYS" />

                <Button styleClass="btn" text="Search" />
            </HBox>

        </VBox>
    </top>

    <!-- ================= BOARD ================= -->
    <center>
        <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" styleClass="scroll" vbarPolicy="NEVER">

            <HBox spacing="24" styleClass="board">

                <!-- COLUMN TEMPLATE -->
                <VBox style="-fx-background-color: #0b0b0b;" styleClass="column">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Circle radius="4" styleClass="dot-green" />
                        <Label styleClass="column-title" text="Backlog 0/0" />
                    </HBox>

                    <Label styleClass="column-desc" text="This item hasn't been started" />
                </VBox>

                <VBox style="-fx-background-color: #0b0b0b;" styleClass="column">
                    <HBox spacing="6">
                        <Circle radius="4" styleClass="dot-blue" />
                        <Label styleClass="column-title" text="Ready 0/0" />
                    </HBox>
                    <Label styleClass="column-desc" text="This is ready to be picked up" />
                </VBox>

                <VBox style="-fx-background-color: #0b0b0b;" styleClass="column">
                    <HBox spacing="6">
                        <Circle radius="4" styleClass="dot-yellow" />
                        <Label styleClass="column-title" text="In progress 0/0" />
                    </HBox>
                    <Label styleClass="column-desc" text="This is actively being worked on" />
                </VBox>

                <VBox style="-fx-background-color: #0b0b0b;" styleClass="column">
                    <HBox spacing="6">
                        <Circle radius="4" styleClass="dot-purple" />
                        <Label styleClass="column-title" text="In review 0/0" />
                    </HBox>
                    <Label styleClass="column-desc" text="This item is in review" />
                </VBox>

                <VBox style="-fx-background-color: #0b0b0b;" styleClass="column">
                    <HBox spacing="6">
                        <Circle radius="4" styleClass="dot-red" />
                        <Label styleClass="column-title" text="Done 0/0" />
                    </HBox>
                    <Label styleClass="column-desc" text="This has been completed" />
                </VBox>

            </HBox>
        </ScrollPane>
    </center>

</BorderPane>
